{
  "name": "@chaingpt/mcp-server",
  "version": "1.10.0",
  "description": "MCP server exposing ChainGPT Web3 AI APIs + generic Web3 tools + mainnet deploy + mainnet DEX (OpenOcean + 1inch + CoW + Jupiter) + mainnet DeFi (Aave + Lido + EigenLayer + Pendle + Morpho) + perps (Hyperliquid + Drift) + Polymarket + Across cross-chain bridge + multi-protocol portfolio snapshot as tools for Claude",
  "main": "dist/index.js",
  "bin": {
    "chaingpt-mcp": "dist/index.js"
  },
  "type": "module",
  "scripts": {
    "build": "node ./node_modules/typescript/bin/tsc",
    "start": "node dist/index.js",
    "dev": "ts-node --esm src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "smoke": "npm run build && node dist/smoke-test.js"
  },
  "dependencies": {
    "@chaingpt/ainews": "^0.0.9",
