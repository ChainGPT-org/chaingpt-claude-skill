    "@chaingpt/nft": "^0.1.2",
    "@chaingpt/smartcontractauditor": "^0.0.2",
    "@chaingpt/smartcontractgenerator": "^0.0.5",
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@msgpack/msgpack": "^3.1.3",
    "@solana/web3.js": "^1.98.4",
    "dotenv": "^16.0.0",
    "qrcode": "^1.5.4",
    "solc": "^0.8.34",
    "viem": "^2.49.3"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/qrcode": "^1.5.6",
    "ts-node": "^10.0.0",
    "typescript": "^5.9.3",
